{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "env": {},
      "disabled": true
    },
    "context7": {
      "command": "npx",
      "args": ["@upstash/context7-mcp@latest"],
      "disabled": false
    }
  }
}
